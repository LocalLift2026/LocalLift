---
import Smudge from "@svg/icons/smudge.svg";
import imageSrc from "@images/Solutions/Audience/who-this-is-for.avif";

import { Image } from "astro:assets";
---

<section id="audience">
  <div class="header-wrapper">
    <h2>
      Who This<span><Smudge class="smudge smudge-specialize" /> Is For</span>
    </h2>

    <p>
      This is for local business owners who are tired of relying only on word of
      mouth and are ready to get found online
    </p>
  </div>

  <Image
    class="image"
    src={imageSrc}
    alt="Cutting Hair Image"
    format="avif"
    quality={70}
  />
</section>

<style>
  section {
    background-color: #1e1e1e;
    padding: min(80px, 10vw);
    align-items: center;
    position: relative;
    display: grid;
    grid-template-columns: min(700px, 50%) min(700px, 50%);
    justify-content: space-evenly;
    color: white;
    gap: 50px;
  }

  .header-wrapper {
    display: flex;
    flex-direction: column;
    max-width: 600px;
    gap: 40px;
    & > p {
      font-size: var(--step-0);
    }
    & > h2 {
      font-size: var(--step-4);
      font-weight: 700;
      margin: 0;
      & > span {
        position: relative;
        & > svg {
          position: absolute;
          width: calc(var(--step-4) * 4.4);
          bottom: -16px;
          right: 0;
          left: -30px;
          transform: scale(1.1, 1.7);
          transform-origin: center;
        }
      }
    }
  }

  .image {
    height: fit-content;
    width: 100%;
    position: relative;
    max-width: 800px;
  }

  @media (max-width: 700px) {
    section {
      grid-template-columns: 1fr;
    }
    * {
      text-align: center;
    }
  }
</style>
