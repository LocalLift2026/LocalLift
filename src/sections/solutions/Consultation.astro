---
import Smudge from "@svg/icons/smudge.svg";
---

<section id="consultation">
  <div class="header-wrapper">
    <h2>
      Ready to Get <span><Smudge />More Clients?</span>
    </h2>
    <p>Let’s build a website that works for your business.</p>
  </div>
  <div
    class="calendly-inline-widget calendly"
    data-url="https://calendly.com/locallift2026/30min"
    style="width:100%;height:700px;"
  >
  </div>
  <script
    type="text/javascript"
    src="https://assets.calendly.com/assets/external/widget.js"
    async></script>
</section>

<style>
  .calendly {
    min-height: 1000px;
  }
  section {
    scroll-margin-top: min(80px, 10vw);
    padding: min(80px, 10vw);
    padding-bottom: 0;
    align-items: center;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-evenly;
    & > p {
      text-align: center;
    }
  }

  .header-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-align: center;
    & > h2 {
      font-size: var(--step-4);
      position: relative;
      margin: 0;
      span {
        position: relative;
        white-space: nowrap;
        & > svg {
          position: absolute;
          width: calc(var(--step-4) * 5);
          bottom: -15px;
          right: unset;
          left: 20px;
          transform: scale(1.3, 0.9);
          transform-origin: center;
        }
      }
    }
  }
</style>
